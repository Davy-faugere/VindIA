# Gabarit de configuration VindIA — copie vers server/.env (ignoré par git).
# La vraie clé Mistral existe déjà sur le VPS ; renseigner server/.env SANS la committer.
# Procédure détaillée : docs/DEPLOY-VPS.md §3.

# --- LLM / STT (souveraineté EU, modèles substituables) ---
MISTRAL_API_KEY=

# --- LiveKit ---
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# --- Base de données MariaDB (ID encodés en CHAR(36), validé) ---
# Mots de passe lus par docker compose (server/.env, jamais committé).
MARIADB_ROOT_PASSWORD=
VINDIA_DB_PASSWORD=
DB_DSN=mysql://vindia:CHANGEME@127.0.0.1:3307/vindia
